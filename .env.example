# Copy this file to .env and fill in your values.
# The pipeline runs without any config — gradient placeholders are used when OPENAI_API_KEY is absent.

# === API Keys ===
# OpenAI key for DALL-E image generation (optional — falls back to gradient placeholders)
OPENAI_API_KEY=

# === Storage ===
# "local" (default) writes to outputs/  |  "azure_blob" uploads to Azure Blob Storage
STORAGE_BACKEND=local

# Required only when STORAGE_BACKEND=azure_blob
# Example format (replace placeholders with real values):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=myaccount;AccountKey=mybase64key==;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=creatives

# === Logging ===
LOG_LEVEL=INFO

# === Server ===
HOST=0.0.0.0
PORT=8000
